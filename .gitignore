# =============================================================================
# Apuntes y archivos a ignorar por Git
# =============================================================================
/_apuntes/
_apuntes/

# =============================================================================
# Environment variables & Configuration (SENSITIVE)
# =============================================================================
.env
.env.local
.env.*.local
.env.production.local

# =============================================================================
# Composer
# =============================================================================
/vendor/
composer.lock

# =============================================================================
# IDE & Editor
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-*
.project
.settings/
.classpath
.c9/

# =============================================================================
# Operating System & Cloud
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.Zone.Identifier

# =============================================================================
# Storage & Uploads
# =============================================================================
/storage/documents/*
!/storage/documents/.gitkeep
/storage/temp/*
!/storage/temp/.gitkeep

# =============================================================================
# Logs & Debug
# =============================================================================
*.log
*.log.*
logs/
debug/

# =============================================================================
# Database backups & dumps
# =============================================================================
*.sql.bak
*.sql.gz
*.dump

# =============================================================================
# Node modules (if used in future)
# =============================================================================
/node_modules/
npm-debug.log
yarn-error.log

# =============================================================================
# PHP-specific
# =============================================================================
.phpunit.result.cache
/coverage/
*.phar

# =============================================================================
# OS temporary files
# =============================================================================
.AppleDouble
.LSOverride
.TemporaryItems
